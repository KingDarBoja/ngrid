{
  "name": "ngrid-material",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ngrid-material/src",
  "projectType": "library",
  "prefix": "pbl",
  "generators": {
    "@nrwl/schematics:component": {
      "styleext": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "ng-cli-packagr-tasks:build",
      "options": {
        "tsConfig": "libs/ngrid-material/tsconfig.lib.json",
        "project": "libs/ngrid-material/ng-package.json",
        "tasks": {
          "config": "tools/ng-packagr.transformers/ngrid-material.transformers.ts",
          "tsConfig": "tools/tsconfig.json",
          "data": {
            "copyFile": {
              "assets": [
                {
                  "glob": "README.md",
                  "input": ".",
                  "output": "dist/@pebula/ngrid-material"
                },
                {
                  "glob": "*.scss",
                  "input": "libs/ngrid-material",
                  "output": "dist/@pebula/ngrid-material"
                },
                {
                  "glob": "**/*.scss",
                  "input": "libs/ngrid-material/theming",
                  "output": "dist/@pebula/ngrid-material/theming"
                },
                {
                  "glob": "*/theming/**/*.scss",
                  "input": "libs/ngrid-material",
                  "output": "dist/@pebula/ngrid-material"
                }
              ]
            },
            "sassCompile": {
              "entries": [
                {
                  "glob": "*.scss",
                  "input": "libs/ngrid-material/theming/prebuilt",
                  "output": "dist/@pebula/ngrid-material/themes"
                }
              ]
            }
          }
        },
        "stylePreprocessorOptions": {
          "sass": {
            "silenceDeprecations": [
              "mixed-decls",
              "color-functions",
              "global-builtin",
              "import"
            ]
          }
        }
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/ngrid-material/tsconfig.lib.prod.json",
          "project": "libs/ngrid-material/ng-package.prod.json"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/ngrid-material/jest.config.js",
        "passWithNoTests": true,
        "tsConfig": "libs/ngrid-material/tsconfig.spec.json"
      },
      "configurations": {
        "ci": {
          "jestConfig": "libs/ngrid-material/jest.config.js",
          "watch": false,
          "progress": false,
          "browsers": "ChromeHeadlessCI"
        }
      },
      "outputs": ["{workspaceRoot}/coverage/libs/ngrid-material"]
    },
    "lint": {
      "executor": "@angular-devkit/build-angular:tslint",
      "options": {
        "tsConfig": [
          "libs/ngrid-material/tsconfig.lib.json",
          "libs/ngrid-material/tsconfig.spec.json"
        ],
        "exclude": ["**/node_modules/**", "!libs/ngrid-material/**/*"]
      }
    }
  }
}
