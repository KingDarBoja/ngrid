{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@pebula/ngrid/core/lib/*": ["core/src/lib/*"],
      "@pebula/ngrid/lib/*": ["src/lib/*"],
      "@pebula/*": ["dist/@pebula/*"]
    },
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "typeRoots": ["../../node_modules/@types"],
    "types": [],
    "moduleResolution": "bundler"
  },
  "exclude": [
    "src/__test-runners/*.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "karma.conf.ts"
  ]
}
