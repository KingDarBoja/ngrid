{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2020",
    "rootDir": ".",
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "typeRoots": ["../../node_modules/@types"],
    "types": [],
    "paths": {
      "@pebula/ngrid/core/lib/*": ["core/src/lib/*"],
      "@pebula/ngrid/lib/*": ["src/lib/*"],
      "@pebula/*": ["dist/@pebula/*"]
    }
  },
  "files": [],
  "include": ["**/*.ts"],
  "exclude": [
    "src/__test-runners/*.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "karma.conf.ts"
  ]
}
